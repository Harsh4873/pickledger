# Copy this file to .env and replace placeholders.
# Never commit your real API keys.

# Anthropic / Claude configuration
ANTHROPIC_API_KEY=INSERT_API_KEY_HERE
# Set this to the Opus 4.5 model id from your Anthropic dashboard/docs.
ANTHROPIC_MODEL=OPUS 4.5
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

# Olostep configuration for Scores24 scraping
OLOSTEP_API_KEY=INSERT_API_KEY_HERE
# Optional: force Scores24 scraping through Olostep or Playwright.
# `auto` prefers Playwright and only uses Olostep when ALLOW_OLOSTEP_AUTO=true.
SCORES24_BACKEND=olostep
# Safety valve: prevent `SCORES24_BACKEND=auto` from spending Olostep credits
# unless you explicitly opt in.
ALLOW_OLOSTEP_AUTO=true
# Optional: country hint passed to Olostep scrapes, e.g. us
OLOSTEP_COUNTRY=
# Optional: wait time before Olostep captures the page
OLOSTEP_WAIT_BEFORE_SCRAPING_MS=2500
# Safety valve: the launchd-driven `scores24_local_sync.py` script exits unless
# this is explicitly enabled.
ENABLE_SCORES24_LOCALSYNC=false

# Optional server settings
HOST=0.0.0.0
PORT=8765
