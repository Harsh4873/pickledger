<body>
<div class="container">

  <header>
    <div>
      <div class="logo-title">PICKLEDGER</div>
      <div class="logo-sub">SOURCE PERFORMANCE TRACKER</div>
    </div>
    <div class="header-right">
      <div class="header-controls">
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <span class="toggle-icon">&#127769;</span>
          <div class="toggle-track"><div class="toggle-thumb"></div></div>
          <span class="toggle-icon">&#9728;&#65039;</span>
          <span class="toggle-label" id="theme-label">DARK</span>
        </button>
        <button id="refresh-btn" class="refresh-btn" onclick="refreshAutoGrades()" aria-label="Auto-grade picks">REFRESH</button>
        <span id="sync-status" style="font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);margin-left:8px;"></span>
      </div>
      <div id="refresh-status" class="refresh-status">Ready to auto-grade</div>
      <div>
        <div class="header-stat-val" id="total-record">0-0</div>
        <div class="header-stat-label">OVERALL RECORD</div>
      </div>
    </div>
  </header>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('home')">HOME</button>
    <button class="tab" onclick="switchTab('search')">SEARCH</button>
    <button class="tab" onclick="switchTab('rankings')">RANKINGS</button>
    <button class="tab" onclick="switchTab('trends')">TRENDS</button>
    <button class="tab" onclick="switchTab('parlays')">PARLAYS</button>
    <button class="tab" onclick="switchTab('models')">MODELS</button>
  </div>

  <!-- HOME TAB -->
  <div id="tab-home" class="tab-content active">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
      <div class="section-title clean-title" style="margin-bottom:0">Pick Log</div>
      <button id="settled-toggle-btn" onclick="toggleShowSettled()" style="background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-weight:600;padding:8px 16px;font-family:'DM Mono',monospace;font-size:14px;letter-spacing:0.5px;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">SHOW SETTLED</button>
    </div>
    <div class="filter-bar" id="filter-bar"></div>
    <div id="settled-stats-panel" style="display:none;margin-bottom:20px;"></div>
    <div class="panel">
      <div id="pick-feed" class="pick-feed"></div>
      <script>
      (function() {
        const feed = document.getElementById('pick-feed');
        feed.addEventListener('mouseover', function(e) {
          const bubble = e.target.closest('.pick-bubble');
          if (bubble) bubble.classList.add('hover-active');
        });
        feed.addEventListener('mouseout', function(e) {
          const bubble = e.target.closest('.pick-bubble');
          if (bubble) bubble.classList.remove('hover-active');
        });
      })();
