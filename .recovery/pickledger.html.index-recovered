  const gameTimes = getGameTimes();

  // Leaderboard (Rankings tab)
  const rankingSources = [...new Set(picks.map(p => getRankingSourceKey(p)))];
  const stats = rankingSources.map(s=>getSourceStats(s)).filter(s=>s&&s.eligible);
