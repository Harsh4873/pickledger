function _canonicalParlayGameLabel(pickText) {
  const matchup = extractGameKey(pickText);
  if (!matchup) return null;
  const parts = matchup.split(/\s+(?:vs|@)\s+/i).map(s => s.trim()).filter(Boolean);
  if (parts.length !== 2) return matchup;
  return `${parts[0]}@${parts[1]}`;
}

function _formatFairAmericanOdds(prob) {
  const fair = Math.round(((1 / prob) - 1) * 100);
  return `${fair > 0 ? '+' : ''}${fair}`;
}

function _getParlaySuggestions() {
  const pendingToday = getPicks().filter(p => p.result === 'pending' && isTodayPickDateLabel(p.date));
  const predictions = pendingToday
    .filter(p => p.sport === 'NBA' && isNbaPropsSource(p.source))
    .map(p => {
      const prob = normalizeProbabilityValue(p.probability);
      const parts = _parsePropPickParts(p.pick);
      return {
        ...p,
        prob,
        edgeNum: Number(p.edge),
        confidenceNum: Number(p.confidence),
        confidencePct: prob == null ? null : prob * 100,
        parts,
        gameLabel: _canonicalParlayGameLabel(p.pick),
      };
    });

  const tier1 = predictions.filter(p =>
    String(p.decision || '').toUpperCase() === 'BET' &&
    p.prob != null &&
    p.prob >= 0.61 &&
    p.prob <= 0.74 &&
    p.parts &&
    p.parts.propWord === 'rebounds'
  );

  const tier2 = predictions.filter(p =>
    String(p.decision || '').toUpperCase() === 'BET' &&
    p.prob != null &&
    p.prob >= 0.65 &&
    p.prob <= 0.74 &&
    p.parts &&
    p.parts.propWord === 'assists'
  );

  const candidates = [...tier1, ...tier2.filter(p => !tier1.includes(p))];
  if (candidates.length < 3) return { tier1: candidates, combos: [] };

  const combos = [];
  for (let i = 0; i < candidates.length - 2; i++) {
    for (let j = i + 1; j < candidates.length - 1; j++) {
      for (let k = j + 1; k < candidates.length; k++) {
        const legs = [candidates[i], candidates[j], candidates[k]];
        const gameCounts = {};
        legs.forEach(leg => {
          const key = leg.gameLabel || `pick-${leg.id}`;
          gameCounts[key] = (gameCounts[key] || 0) + 1;
        });
        if (Math.max(...Object.values(gameCounts)) > 2) continue;
        const combinedProb = legs.reduce((acc, leg) => acc * leg.prob, 1);
        combos.push({
          legs,
          gameCounts,
          combinedProb,
          uniqueGameCount: Object.keys(gameCounts).length,
        });
      }
    }
  }

  combos.sort((a, b) => {
    if (b.uniqueGameCount !== a.uniqueGameCount) return b.uniqueGameCount - a.uniqueGameCount;
    return b.combinedProb - a.combinedProb;
  });

  return { tier1, combos: combos.slice(0, 3) };
}

function renderParlays() {
  const container = document.getElementById('parlays-container');
  if (!container) return;
  const { tier1, combos } = _getParlaySuggestions();

  if (tier1.length < 3 || !combos.length) {
    const bestAvailable = [...tier1]
      .sort((a, b) => (b.prob || 0) - (a.prob || 0))
      .slice(0, 5)
      .map(p => `${p.parts ? p.parts.playerName : p.pick} (${((p.prob || 0) * 100).toFixed(1)}%)`)
      .join(', ');
    container.innerHTML = `
      <div class="section-title clean-title">Parlay Suggestions</div>
      <div class="parlay-subtitle">Tier 1: reb 61-74% | Tier 2 fill: ast 65-74%</div>
      <div class="empty-state">⚠️  Thin slate today — only ${tier1.length} Tier 1 candidates. Straights only recommended.<br>Best available: ${bestAvailable || 'None'}</div>
    `;
    return;
  }

  const cards = combos.map((combo, idx) => {
    const correlatedGame = Object.entries(combo.gameCounts).find(([, count]) => count === 2)?.[0] || null;
      const legsHtml = combo.legs.map((leg, legIdx) => {
        const propShort = leg.parts.propWord === 'assists' ? 'ast' : 'reb';
        return `
        <div class="parlay-leg">
          <div class="parlay-leg-main">Leg ${legIdx + 1}: ${leg.parts.playerName} | ${propShort} ${leg.parts.direction} ${leg.parts.line.toFixed(1)}</div>
          <div class="parlay-leg-meta">Edge ${leg.edgeNum.toFixed(1)}% | Conf ${Math.round(leg.confidenceNum)}%</div>
        </div>
      `;
    }).join('');
    return `
      <div class="parlay-card">
        <div class="parlay-header">
          <div class="parlay-title">COMBO ${idx + 1}</div>
          <div class="parlay-meta">Combined Prob: ${(combo.combinedProb * 100).toFixed(1)}%<br>Fair Odds: ${_formatFairAmericanOdds(combo.combinedProb)}</div>
        </div>
        ${legsHtml}
        ${correlatedGame ? `<div class="parlay-warn">⚠️  2 legs from same game (${correlatedGame}) — correlated risk</div>` : ''}
      </div>
    `;
  }).join('');

  container.innerHTML = `
    <div class="section-title clean-title">Parlay Suggestions</div>
    <div class="parlay-subtitle">Tier 1: reb 61-74% | Tier 2 fill: ast 65-74%</div>
    <div class="parlay-grid">${cards}</div>
    <div class="parlay-footnote">Top 3 combos sorted by game diversity first (3 unique games), then combined probability.</div>
  `;
}

