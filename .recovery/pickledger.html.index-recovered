async function _pollJob(jobId, model, baseUrl = MODEL_SERVER, timeoutMs = 600000) {
  const pollInterval = 3000; // 3 seconds
  const started = Date.now();
  while (true) {
    const elapsedMs = Date.now() - started;
    if (elapsedMs > timeoutMs) {
      setModelStatus(model, 'Timed out waiting for model job', 'error');
      return null;
    }

    await new Promise(r => setTimeout(r, pollInterval));
    try {
      if (model === 'scores24') {
        const secs = Math.floor(elapsedMs / 1000);
        setModelStatus(model, `Running local Scores24 scrape... ${secs}s`, 'running');
      } else if (model === 'sportytrader') {
        const secs = Math.floor(elapsedMs / 1000);
        setModelStatus(model, `Running local SportyTrader scrape... ${secs}s`, 'running');
      }

      const resp = await fetch(`${baseUrl}/job-status?id=${jobId}`);
      const data = await resp.json();
      if (data.status === 'done') {
        return data;
      }
      // still running
    } catch (e) {
      setModelStatus(model, 'Lost connection while polling...', 'error');
      return null;
    }
  }
}

