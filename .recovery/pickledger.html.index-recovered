  GSW: ['Warriors'], HOU: ['Rockets'], IND: ['Pacers'], LAC: ['Clippers'], LAL: ['Lakers'],
  MEM: ['Grizzlies'], MIA: ['Heat'], MIL: ['Bucks'], MIN: ['Timberwolves', 'Wolves'],
  NOP: ['Pelicans'], NYK: ['Knicks'], OKC: ['Thunder'], ORL: ['Magic'], PHI: ['76ers', 'Sixers'],
