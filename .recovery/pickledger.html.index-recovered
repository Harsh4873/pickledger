<script>
// ╔══════════════════════════════════════════════════════════════╗
// ║  PICK DATA — edited whenever new picks are logged           ║
// ╚══════════════════════════════════════════════════════════════╝
const PICKS = [];

// ── Engine ──
const STORAGE_VERSION = '2026_03_19_reset_v2';
const ADDED_PICKS_KEY = `pickledger_added_picks_${STORAGE_VERSION}`;
const DELETED_PICKS_KEY = `pickledger_deleted_pick_ids_${STORAGE_VERSION}`;
const RESULTS_KEY = `pickledger_results_${STORAGE_VERSION}`;
const GAME_TIMES_KEY = `pickledger_game_times_${STORAGE_VERSION}`;
const ONE_TIME_PROPS_CLEANUP_KEY = `pickledger_cleanup_nba_props_${STORAGE_VERSION}`;
const RESET_CUTOFF_ISO = '2026-03-19T00:00:00.000Z';
let activeFilter = 'ALL';
let showSettled = false;
const DEFAULT_MODEL_SERVER = 'http://127.0.0.1:8765';
const QUERY_MODEL_SERVER = (new URLSearchParams(window.location.search).get('api') || '').trim();
const SAVED_MODEL_SERVER = (localStorage.getItem('pickledger_model_server') || '').trim();
const IS_SAVED_REMOTE = /^https?:\/\/(?!127\.0\.0\.1|localhost)/i.test(SAVED_MODEL_SERVER);
const MODEL_SERVER = QUERY_MODEL_SERVER || (IS_SAVED_REMOTE ? DEFAULT_MODEL_SERVER : (SAVED_MODEL_SERVER || DEFAULT_MODEL_SERVER));
if (!QUERY_MODEL_SERVER && IS_SAVED_REMOTE) {
  localStorage.setItem('pickledger_model_server', DEFAULT_MODEL_SERVER);
}
const GRADER_URL = `${MODEL_SERVER}/grade`;
const LEDGER_STATE_URL = `${MODEL_SERVER}/api/ledger-state`;
const SCORES24_FEED_URL = './scores24_manual_feed.json';
const SCORES24_CACHE_KEY = 'pickledger_scores24_feed_cache';
const SPORTYTRADER_FEED_URL = './sportytrader_manual_feed.json';
const SPORTYTRADER_CACHE_KEY = 'pickledger_sportytrader_feed_cache';
const LOCAL_SCORES24_SERVER = 'http://127.0.0.1:8765';
const LOCAL_SPORTYTRADER_SERVER = 'http://127.0.0.1:8765';
let ledgerStateSyncTimer = null;
let ledgerStateSyncInFlight = false;

function getAddedPicks() {
  try {
    const raw = localStorage.getItem(ADDED_PICKS_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    const list = Array.isArray(parsed) ? parsed : [];
    return list.map(p => ({ ...p, units: 1 }));
  } catch {
    return [];
  }
}

function saveAddedPicks(list) {
  localStorage.setItem(ADDED_PICKS_KEY, JSON.stringify(list));
  scheduleLedgerStateSync();
}

function getDeletedPickIds() {
  try {
    const raw = localStorage.getItem(DELETED_PICKS_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed.map(v => String(v)) : [];
  } catch {
    return [];
  }
}

function saveDeletedPickIds(ids) {
  localStorage.setItem(DELETED_PICKS_KEY, JSON.stringify(ids));
  scheduleLedgerStateSync();
}

function runOneTimeNbaPropsCleanup(state) {
  if (localStorage.getItem(ONE_TIME_PROPS_CLEANUP_KEY) === '1') return 0;
  const sourceState = (state && typeof state === 'object') ? state : {
    addedPicks: (() => {
      try {
        const raw = localStorage.getItem(ADDED_PICKS_KEY);
        const parsed = raw ? JSON.parse(raw) : [];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    })(),
    deletedPickIds: getDeletedPickIds(),
    results: getResults(),
    gameTimes: getGameTimes(),
  };

  const added = Array.isArray(sourceState.addedPicks) ? sourceState.addedPicks : [];
  const removedIds = new Set();
  const kept = added.filter(p => {
    const remove = String((p && p.source) || '') === 'NBA Props Model';
    if (remove && p && p.id != null) removedIds.add(String(p.id));
    return !remove;
  });
  const removed = added.length - kept.length;

  if (removed > 0) {
    const deleted = Array.isArray(sourceState.deletedPickIds) ? sourceState.deletedPickIds.map(v => String(v)) : [];
    const results = (sourceState.results && typeof sourceState.results === 'object') ? { ...sourceState.results } : {};
    const gameTimes = (sourceState.gameTimes && typeof sourceState.gameTimes === 'object') ? { ...sourceState.gameTimes } : {};
    removedIds.forEach(id => { delete results[id]; delete gameTimes[id]; });
    localStorage.setItem(ADDED_PICKS_KEY, JSON.stringify(kept));
    localStorage.setItem(DELETED_PICKS_KEY, JSON.stringify(deleted.filter(id => !removedIds.has(String(id)))));
    localStorage.setItem(RESULTS_KEY, JSON.stringify(results));
    Object.entries(results).forEach(([id, result]) => saveResultToServer(id, result));
    localStorage.setItem(GAME_TIMES_KEY, JSON.stringify(gameTimes));
    scheduleLedgerStateSync();
  }
  localStorage.setItem(ONE_TIME_PROPS_CLEANUP_KEY, '1');
  return removed;
}

function getAllLedgerPicks() {
  const deleted = new Set(getDeletedPickIds());
  return [...PICKS, ...getAddedPicks()].filter(p => !deleted.has(String(p.id)));
}

function hasMeaningfulLocalState() {
  return (
    getAddedPicks().length > 0 ||
    getDeletedPickIds().length > 0 ||
    Object.keys(getResults()).length > 0 ||
    Object.keys(getGameTimes()).length > 0
  );
}

function buildLedgerStatePayload() {
  return {
    version: 1,
    savedAt: new Date().toISOString(),
    addedPicks: getAddedPicks(),
    deletedPickIds: getDeletedPickIds(),
    results: getResults(),
    gameTimes: getGameTimes(),
  };
}

function applyLedgerStateFromServer(state) {
  if (!state || typeof state !== 'object') return false;
  const removedProps = runOneTimeNbaPropsCleanup(state);
  const addedRaw = Array.isArray(state.addedPicks) ? state.addedPicks : [];
  const removedIds = new Set(addedRaw
    .filter(p => String((p && p.source) || '') === 'NBA Props Model' && p && p.id != null)
    .map(p => String(p.id)));
  const added = addedRaw.filter(p => String((p && p.source) || '') !== 'NBA Props Model');
  const deletedRaw = Array.isArray(state.deletedPickIds) ? state.deletedPickIds.map(v => String(v)) : [];
  const deleted = deletedRaw.filter(id => !removedIds.has(String(id)));
  const resultsRaw = (state.results && typeof state.results === 'object') ? state.results : {};
  const results = { ...resultsRaw };
  const gameTimesRaw = (state.gameTimes && typeof state.gameTimes === 'object') ? state.gameTimes : {};
  const gameTimes = { ...gameTimesRaw };
  removedIds.forEach(id => { delete results[id]; delete gameTimes[id]; });
  const hasAny = added.length || deleted.length || Object.keys(results).length || Object.keys(gameTimes).length;
  if (!hasAny) return false;

  localStorage.setItem(ADDED_PICKS_KEY, JSON.stringify(added));
  localStorage.setItem(DELETED_PICKS_KEY, JSON.stringify(deleted));
  localStorage.setItem(RESULTS_KEY, JSON.stringify(results));
  Object.entries(results).forEach(([id, result]) => saveResultToServer(id, result));
  localStorage.setItem(GAME_TIMES_KEY, JSON.stringify(gameTimes));
  if (removedProps > 0) scheduleLedgerStateSync();
  return true;
}

async function pushLedgerState(force = false) {
  if (!LEDGER_STATE_URL) return;
  if (ledgerStateSyncInFlight && !force) return;
  ledgerStateSyncInFlight = true;
  try {
    await fetch(LEDGER_STATE_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ state: buildLedgerStatePayload() }),
    });
  } catch {
    // Best-effort backup only.
  } finally {
    ledgerStateSyncInFlight = false;
  }
}

function scheduleLedgerStateSync() {
  if (ledgerStateSyncTimer) {
    clearTimeout(ledgerStateSyncTimer);
  }
  ledgerStateSyncTimer = setTimeout(() => {
    pushLedgerState(false);
  }, 1200);
}

async function pullLedgerStateIfNeeded() {
  if (hasMeaningfulLocalState() || !LEDGER_STATE_URL) return false;
  try {
    const res = await fetch(LEDGER_STATE_URL, { method: 'GET' });
    if (!res.ok) return false;
    const data = await res.json();
    if (!data || !data.ok) return false;
    const restored = applyLedgerStateFromServer(data.state || {});
    if (restored) {
      render();
      if (document.getElementById('tab-search').classList.contains('active')) {
        renderSearch();
      }
      setRefreshStatus('Recovered ledger state from backend backup', 'ok');
      return true;
    }
  } catch {
    // Ignore restore failures; local storage remains source-of-truth.
  }
  return false;
}

function toggleMoreFilters(e) {
  e.stopPropagation();
  const dd = document.getElementById('filter-dropdown');
  if (dd) dd.classList.toggle('open');
}
function closeMoreFilters() {
  const dd = document.getElementById('filter-dropdown');
  if (dd) dd.classList.remove('open');
}
document.addEventListener('click', function(e) {
  const wrap = document.querySelector('.filter-more-wrap');
  if (wrap && !wrap.contains(e.target)) closeMoreFilters();
});

function setRefreshStatus(msg, state) {
  const el = document.getElementById('refresh-status');
  if (!el) return;
  el.textContent = msg;
  el.classList.remove('error', 'ok');
  if (state === 'error') el.classList.add('error');
  if (state === 'ok') el.classList.add('ok');
}

function setSyncStatus(state) {
  const el = document.getElementById('sync-status');
  if (!el) return;
  if (state === 'synced') { el.textContent = '✓ synced'; el.style.color = 'var(--win)'; }
  else if (state === 'syncing') { el.textContent = 'syncing...'; el.style.color = 'var(--muted)'; }
  else { el.textContent = 'offline'; el.style.color = 'var(--muted)'; }
}

function saveResultToServer(id, result) {
  fetch(`${MODEL_SERVER}/picks/save-result`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ results: { [id]: result } })
  }).catch(() => {});
}

async function syncWithServer() {
  setSyncStatus('syncing');
  try {
    const res = await fetch(`${MODEL_SERVER}/picks/all`, { signal: AbortSignal.timeout(4000) });
    if (!res.ok) throw new Error('bad response');
    const data = await res.json();

    const local = getResults();
    const merged = { ...local, ...data.results };
    localStorage.setItem(RESULTS_KEY, JSON.stringify(merged));

    const serverIds = new Set(data.picks.map(p => String(p.id)));
    const added = getAddedPicks();
    for (const p of added) {
      if (!serverIds.has(String(p.id))) {
        fetch(`${MODEL_SERVER}/picks/save-pick`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(p)
        }).catch(() => {});
      }
    }

    setSyncStatus('synced');
    render();
  } catch {
    setSyncStatus('offline');
  }
}

async function refreshAutoGrades(silent = false) {
  const btn = document.getElementById('refresh-btn');
  if (!btn) return;

  if (!silent) {
    btn.disabled = true;
    btn.textContent = 'REFRESHING';
    setRefreshStatus('Calling local grader + live score APIs...', 'ok');
  } else {
    setRefreshStatus('Syncing game start times...', 'ok');
  }

  try {
    const payload = {
      picks: getAllLedgerPicks(),
      existing: getResults(),
      year: new Date().getFullYear(),
    };

    const res = await fetch(GRADER_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!res.ok) throw new Error('grader http error');
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'grader failed');

    const graded = data.graded || {};
    const merged = getResults();
    Object.entries(graded).forEach(([id, result]) => {
      merged[id] = result;
      saveResultToServer(id, result);
    });
    localStorage.setItem(RESULTS_KEY, JSON.stringify(merged));

    const startTimes = data.startTimes || {};
    const mergedTimes = getGameTimes();
    Object.entries(startTimes).forEach(([id, iso]) => {
      if (iso) mergedTimes[id] = iso;
    });
    localStorage.setItem(GAME_TIMES_KEY, JSON.stringify(mergedTimes));
    scheduleLedgerStateSync();

    render();
    if (document.getElementById('tab-search').classList.contains('active')) {
      renderSearch();
    }

    const summary = data.summary || {};
    const updated = summary.updated || 0;
    const attempted = summary.attempted || 0;
    const syncedTimes = Object.keys(startTimes).length;
    setRefreshStatus(`Updated ${updated} picks, synced ${syncedTimes} start times (${attempted} checked)`, 'ok');
  } catch (err) {
    if (!silent) setRefreshStatus('Grader offline. Start: python3 pickgrader_server.py', 'error');
  } finally {
    syncWithServer().catch(() => setSyncStatus('offline'));
    if (!silent) {
      btn.disabled = false;
      btn.textContent = 'REFRESH';
    }
  }
}

function toggleShowSettled() {
  showSettled = !showSettled;
  const btn = document.getElementById('settled-toggle-btn');
  if (showSettled) {
    btn.style.color = 'var(--accent3)';
    btn.style.borderColor = 'var(--accent3)';
    btn.textContent = 'SHOW PENDING';
  } else {
    btn.style.color = 'var(--muted)';
    btn.style.borderColor = 'var(--border)';
    btn.textContent = 'SHOW SETTLED';
  }
  render();
}

function calcPL(u,r) {
  if(r==='push'||r==='pending') return 0;
  if(r==='loss') return -u;
  return u;
}
function normalizeOddsValue(value) {
  if (value == null || value === '') return null;
  const num = Number(value);
  return Number.isFinite(num) ? num : null;
}
function formatOddsDisplay(odds) {
  const num = normalizeOddsValue(odds);
  if (num == null) return '—';
  return `${num > 0 ? '+' : ''}${num}`;
}
function normalizeProbabilityValue(value) {
  if (value == null || value === '') return null;
  const num = Number(value);
  return Number.isFinite(num) && num >= 0 && num <= 1 ? num : null;
}
function formatOddsOrProbabilityDisplay(odds, probability) {
  const oddsStr = formatOddsDisplay(odds);
  if (oddsStr !== '—') return oddsStr;
  const prob = normalizeProbabilityValue(probability);
  if (prob == null) return '—';
  return `${(prob * 100).toFixed(1)}%`;
}
function getResults() { return JSON.parse(localStorage.getItem(RESULTS_KEY)||'{}'); }
function getGameTimes() { return JSON.parse(localStorage.getItem(GAME_TIMES_KEY)||'{}'); }

function deletePick(id) {
  const idStr = String(id);

  const deleted = new Set(getDeletedPickIds());
  deleted.add(idStr);
  saveDeletedPickIds([...deleted]);

  const keptAdded = getAddedPicks().filter(p => String(p.id) !== idStr);
  saveAddedPicks(keptAdded);

  const results = getResults();
  if (Object.prototype.hasOwnProperty.call(results, idStr)) {
    delete results[idStr];
    saveResultToServer(idStr, 'deleted');
    localStorage.setItem(RESULTS_KEY, JSON.stringify(results));
  }

  const gameTimes = getGameTimes();
  if (Object.prototype.hasOwnProperty.call(gameTimes, idStr)) {
    delete gameTimes[idStr];
    localStorage.setItem(GAME_TIMES_KEY, JSON.stringify(gameTimes));
  }

  render();
  if (document.getElementById('tab-search').classList.contains('active')) {
    renderSearch();
  }
}

function setResult(id,r) {
  if (r === 'delete') {
    deletePick(id);
    return;
  }
  const o=getResults();
  o[id]=r;
  localStorage.setItem(RESULTS_KEY,JSON.stringify(o));
  saveResultToServer(id, r);
  scheduleLedgerStateSync();
  render();
}

function missingStartTimesCount() {
  const supported = new Set(['NBA', 'NHL', 'MLB', 'EPL', 'WBC']);
  const times = getGameTimes();
  return getPicks().filter(p => p.result === 'pending' && supported.has(p.sport) && !times[String(p.id)]).length;
}

function parsePickDateLabel(d) {
  const dt = new Date(`${d} ${new Date().getFullYear()} 00:00:00`);
  return Number.isNaN(dt.getTime()) ? null : dt;
}

function isTodayPickDateLabel(d) {
  const dt = parsePickDateLabel(d);
  if (!dt) return false;
  const now = new Date();
  return dt.getMonth() === now.getMonth() && dt.getDate() === now.getDate();
}

function formatTodayPickDateLabel() {
  return new Date().toLocaleString('en-US', { month: 'short', day: 'numeric' });
}

function formatStartLabel(iso) {
  if (!iso) return 'TBD';
  const dt = new Date(iso);
  if (Number.isNaN(dt.getTime())) return 'TBD';
  return dt.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
}

function getGameKeyForPick(p) {
  const label = extractGameKey(p.pick) || inferNbaPropsMatchupLabel(p, getPicks());
  return label || `${p.sport}::${p.date}::${p.id}`;
}

function formatSourceRecordLine(label, picks) {
  const wins = picks.filter(p => p.result === 'win').length;
  const losses = picks.filter(p => p.result === 'loss').length;
  const pushes = picks.filter(p => p.result === 'push').length;
  const netUnits = picks.reduce((sum, p) => sum + p.pl, 0);
  const record = pushes > 0 ? `${wins}-${losses}-${pushes}` : `${wins}-${losses}`;
  return { label, text: `${record} | ${netUnits >= 0 ? '+' : ''}${netUnits}u` };
}

function getSourcePastRecordLines(source) {
  const todayStart = new Date();
  todayStart.setHours(0, 0, 0, 0);

  const yesterdayStart = new Date(todayStart);
  yesterdayStart.setDate(yesterdayStart.getDate() - 1);

  const lastWeekStart = new Date(todayStart);
  lastWeekStart.setDate(lastWeekStart.getDate() - 7);

  const sourcePicks = getPicks()
    .filter(p => getRankingSourceKey(p) === source && p.result !== 'pending')
    .map(p => ({ ...p, parsedDate: parsePickDateLabel(p.date) }));

  const yesterdayPicks = sourcePicks.filter(p => p.parsedDate && p.parsedDate >= yesterdayStart && p.parsedDate < todayStart);
  const lastWeekPicks = sourcePicks.filter(p => p.parsedDate && p.parsedDate >= lastWeekStart && p.parsedDate < todayStart);

  return [
    formatSourceRecordLine('YESTERDAY', yesterdayPicks),
    formatSourceRecordLine('LAST WEEK', lastWeekPicks),
    formatSourceRecordLine('OVERALL', sourcePicks),
  ];
}

