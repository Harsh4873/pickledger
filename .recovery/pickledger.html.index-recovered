async function syncScores24FromServer(sports = ['nba', 'nhl', 'mlb']) {
  const server = LOCAL_SCORES24_SERVER;
  const selectedSports = Array.isArray(sports) ? sports.map(s => String(s || '').toLowerCase().trim()).filter(Boolean) : [];

  const body = {
    async: true,
    date: _getTodayDateStr(),
    sports: selectedSports.length ? selectedSports : ['nba', 'nhl', 'mlb'],
  };

  const resp = await fetch(server + '/run-scores24', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });

  const launch = await resp.json();
  if (!launch.ok) {
    throw new Error(launch.error || `HTTP ${resp.status}`);
  }

  let data = launch;
  if (launch.job_id) {
    data = await _pollJob(launch.job_id, 'scores24', server, 600000);
  }
  if (!data || !data.ok) {
    throw new Error((data && data.error) || 'Scores24 job failed');
  }

  return {
    picks: Array.isArray(data.picks) ? data.picks : [],
    meta: {
      updatedAt: new Date().toISOString(),
      date: _getTodayDateStr(),
      note: 'Synced from localhost backend',
      from: 'local-backend',
      leagues: body.sports.join(','),
    },
  };
}

async function syncSportyTraderFromServer() {
  const body = { async: true, date: _getTodayDateStr() };
  const modelBase = String(MODEL_SERVER || '').trim().replace(/\/+$/, '');
  const candidates = [MODEL_SERVER, LOCAL_SPORTYTRADER_SERVER]
    .map(v => String(v || '').trim().replace(/\/+$/, ''))
    .filter((v, i, arr) => v && arr.indexOf(v) === i);
  let lastErr = 'SportyTrader sync failed';

  for (const server of candidates) {
    const routes = /\/api$/i.test(server) ? ['/run-sportytrader'] : ['/run-sportytrader', '/api/run-sportytrader'];
    for (const route of routes) {
      try {
        const resp = await fetch(`${server}${route}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const launch = await resp.json();
        if (!launch.ok) throw new Error(launch.error || `HTTP ${resp.status}`);

        let data = launch;
        if (launch.job_id) {
          const pollBase = `${server}${route}`.replace(/\/(?:api\/)?run-sportytrader$/, '');
          data = await _pollJob(launch.job_id, 'sportytrader', pollBase, 600000);
        }
        if (!data || !data.ok) throw new Error((data && data.error) || 'SportyTrader job failed');

        const picks = Array.isArray(data.picks) ? data.picks.filter(p => String(p.sport || '').toUpperCase() === 'NBA') : [];
        return {
          picks,
          meta: {
            updatedAt: new Date().toISOString(),
            date: _getTodayDateStr(),
            note: 'Synced from backend',
            from: (server === modelBase ? 'render-backend' : 'local-backend'),
          },
        };
      } catch (e) {
        lastErr = String(e && e.message ? e.message : e);
      }
    }
  }

  throw new Error(lastErr);
}

async function runSelectedScores24League() {
  const btn = document.getElementById('btn-run-scores24-league');
  const select = document.getElementById('scores24-league-select');
  const league = String(select && select.value ? select.value : 'nba').toLowerCase();
  if (btn) { btn.disabled = true; btn.textContent = 'RUNNING...'; }
  setModelStatus('scores24', `Syncing Scores24 ${league.toUpperCase()} only...`, 'running');
  try {
    const synced = await syncScores24FromServer([league]);
    pendingModelPicks = synced.picks;
    renderModelResults(synced.picks);
    saveScores24CachedFeed({ picks: synced.picks, meta: synced.meta });
    setScores24SyncMeta(synced.meta);
    setModelStatus('scores24', `Synced ${synced.picks.length} ${league.toUpperCase()} pick(s)`, 'ok');
  } catch (e) {
    const err = String(e && e.message ? e.message : e);
    // Fallback 1: try the manual feed file
    try {
      const loaded = await loadScores24ManualFeed();
      const sportMap = { nba: 'NBA', nhl: 'NHL', mlb: 'MLB' };
      const targetSport = sportMap[league] || league.toUpperCase();
      const filtered = (loaded.picks || []).filter(p => String(p.sport || '').toUpperCase() === targetSport);
      if (filtered.length) {
        const meta = {
          ...loaded.meta,
          updatedAt: loaded.meta && loaded.meta.updatedAt ? loaded.meta.updatedAt : new Date().toISOString(),
          date: loaded.meta && loaded.meta.date ? loaded.meta.date : _getTodayDateStr(),
          from: 'feed-fallback',
          leagues: league,
          note: loaded.meta && loaded.meta.note ? loaded.meta.note : 'Loaded from manual feed after backend failure',
        };
        pendingModelPicks = filtered;
        renderModelResults(filtered);
        saveScores24CachedFeed({ picks: filtered, meta });
        setScores24SyncMeta(meta);
        setModelStatus('scores24', `Backend unavailable; loaded ${filtered.length} ${league.toUpperCase()} pick(s) from feed`, 'ok');
      } else {
        throw new Error('no matching picks in feed');
      }
    } catch {
      // Fallback 2: try the browser localStorage cache
      const cached = getScores24CachedFeed();
      if (cached && Array.isArray(cached.picks) && cached.picks.length) {
        const sportMap = { nba: 'NBA', nhl: 'NHL', mlb: 'MLB' };
        const targetSport = sportMap[league] || league.toUpperCase();
        const filtered = cached.picks.filter(p => String(p.sport || '').toUpperCase() === targetSport);
        if (filtered.length) {
          pendingModelPicks = filtered;
          renderModelResults(filtered);
          setScores24SyncMeta({ ...(cached.meta || {}), from: 'cache', leagues: league });
          setModelStatus('scores24', `Using cached ${filtered.length} ${league.toUpperCase()} pick(s)`, 'ok');
        } else {
          setModelStatus('scores24', `League sync failed (${err})`, 'error');
        }
      } else {
        setModelStatus('scores24', `League sync failed (${err})`, 'error');
      }
    }
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.textContent = 'SYNC SELECTED LEAGUE';
    }
  }
}

async function runModel(model) {
  const btn = document.getElementById('btn-run-' + model);
  if (btn) { btn.disabled = true; btn.textContent = 'RUNNING...'; }
  setModelStatus(model, 'Connecting to server...', 'running');

  if (model === 'scores24') {
    let backendErr = '';
    try {
      setModelStatus(model, 'Trying live Scores24 backend sync...', 'running');
      const synced = await syncScores24FromServer();
      pendingModelPicks = synced.picks;
      renderModelResults(synced.picks);
      saveScores24CachedFeed({ picks: synced.picks, meta: synced.meta });
      setScores24SyncMeta(synced.meta);
      setModelStatus(model, `Synced ${synced.picks.length} pick(s) from backend`, 'ok');
    } catch (e) {
      backendErr = String(e && e.message ? e.message : e);
      try {
        setModelStatus(model, 'Backend sync unavailable, loading feed file...', 'running');
        const loaded = await loadScores24ManualFeed();
        pendingModelPicks = loaded.picks;
        renderModelResults(loaded.picks);

        const meta = {
          ...loaded.meta,
          from: 'feed-file',
          updatedAt: loaded.meta.updatedAt || new Date().toISOString(),
        };
        saveScores24CachedFeed({ picks: loaded.picks, meta });
        setScores24SyncMeta(meta);
        setModelStatus(model, `Loaded ${loaded.picks.length} pick(s) from feed file`, 'ok');
      } catch (feedErr) {
        const cached = getScores24CachedFeed();
        if (cached && Array.isArray(cached.picks)) {
          pendingModelPicks = cached.picks;
          renderModelResults(cached.picks);
          setScores24SyncMeta({ ...(cached.meta || {}), from: 'cache' });
          setModelStatus(model, `Using cached Scores24 feed (${cached.picks.length} pick(s))`, 'ok');
        } else {
          const feedMsg = String(feedErr && feedErr.message ? feedErr.message : feedErr);
          setModelStatus(model, `Sync failed (${backendErr}); feed unavailable (${feedMsg})`, 'error');
        }
      }
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'SYNC SCORES24 NOW';
      }
    }
    return;
  }

  if (model === 'sportytrader') {
    let backendErr = '';
    try {
      setModelStatus(model, 'Trying live SportyTrader backend sync...', 'running');
      const synced = await syncSportyTraderFromServer();
      pendingModelPicks = synced.picks;
      renderModelResults(synced.picks);
      saveSportyTraderCachedFeed({ picks: synced.picks, meta: synced.meta });
      setSportyTraderSyncMeta(synced.meta);
      setModelStatus(model, `Synced ${synced.picks.length} NBA pick(s) from backend`, 'ok');
    } catch (e) {
      backendErr = String(e && e.message ? e.message : e);
      try {
        setModelStatus(model, 'Backend sync unavailable, loading feed file...', 'running');
        const loaded = await loadSportyTraderManualFeed();
        pendingModelPicks = loaded.picks;
        renderModelResults(loaded.picks);
        const meta = {
          ...loaded.meta,
          from: 'feed-file',
          updatedAt: loaded.meta.updatedAt || new Date().toISOString(),
        };
        saveSportyTraderCachedFeed({ picks: loaded.picks, meta });
        setSportyTraderSyncMeta(meta);
        setModelStatus(model, `Loaded ${loaded.picks.length} NBA pick(s) from feed file`, 'ok');
      } catch (feedErr) {
        const cached = getSportyTraderCachedFeed();
        if (cached && Array.isArray(cached.picks)) {
          pendingModelPicks = cached.picks;
          renderModelResults(cached.picks);
          setSportyTraderSyncMeta({ ...(cached.meta || {}), from: 'cache' });
          setModelStatus(model, `Using cached SportyTrader feed (${cached.picks.length} pick(s))`, 'ok');
        } else {
          const feedMsg = String(feedErr && feedErr.message ? feedErr.message : feedErr);
          setModelStatus(model, `Sync failed (${backendErr}); feed unavailable (${feedMsg})`, 'error');
        }
      }
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'SYNC SPORTYTRADER NOW';
      }
    }
    return;
  }

  let endpoint = '';
  let body = { async: true, date: _getTodayDateStr() };
  if (model === 'mlb') endpoint = '/run-mlb-model';
  else if (model === 'nba') endpoint = '/run-nba-model';
  else if (model === 'nba-props') {
    endpoint = '/run-nba-props-model';
    const gameSelect = document.getElementById('nba-props-game-select');
    const selectedGameLabel = String(gameSelect && gameSelect.value ? gameSelect.value : '').trim();
    if (selectedGameLabel) {
      body.game_label = selectedGameLabel;
    }
  }

  try {
    setModelStatus(model, 'Launching model (async)...', 'running');
    const resp = await fetch(MODEL_SERVER + endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const launch = await resp.json();
    if (!launch.ok) {
      setModelStatus(model, 'Error: ' + (launch.error || 'Unknown error'), 'error');
      return;
    }

    if (launch.job_id) {
      // Async mode — poll for results
      setModelStatus(model, 'Model is running in background — polling for results...', 'running');
      const data = await _pollJob(launch.job_id, model);
      if (!data || !data.ok) {
        setModelStatus(model, 'Error: ' + ((data && data.error) || 'Job failed'), 'error');
        return;
      }
      const picks = data.picks || [];
      setModelStatus(model, `Done. ${picks.length} prediction(s) returned.`, 'ok');
      pendingModelPicks = picks;
      renderModelResults(picks);
    } else {
      // Sync fallback (shouldn't happen but just in case)
      const picks = launch.picks || [];
      setModelStatus(model, `Done. ${picks.length} prediction(s) returned.`, 'ok');
      pendingModelPicks = picks;
      renderModelResults(picks);
    }
  } catch (e) {
    setModelStatus(model, `Server not reachable at ${MODEL_SERVER}`, 'error');
  } finally {
    if (btn) {
      btn.disabled = false;
      const labels = {
        mlb: 'RUN MLB MODEL',
        nba: 'RUN NBA MODEL',
        'nba-props': 'RUN PROPS MODEL',
        scores24: 'SYNC SCORES24 NOW',
        sportytrader: 'SYNC SPORTYTRADER NOW'
      };
      btn.textContent = labels[model] || 'RUN';
    }
  }
}

function renderModelResults(picks) {
  const section = document.getElementById('model-results-section');
  const tbody = document.getElementById('model-results-body');
  if (!picks.length) {
    section.style.display = 'none';
    return;
  }
  section.style.display = 'block';
  tbody.innerHTML = picks.map((p, idx) => {
    const isBet = p.decision === 'BET';
    const cls = isBet ? 'model-result-bet' : 'model-result-pass';
    const edgeStr = p.edge != null ? (p.edge > 0 ? '+' : '') + p.edge.toFixed(1) + '%' : '—';
    const probStr = p.probability != null ? (p.probability * 100).toFixed(1) + '%' : '—';
    const oddsStr = formatOddsDisplay(p.odds);
    return `<tr class="${isBet ? '' : 'model-result-pass-row'}" style="${isBet ? '' : 'opacity:0.5'}">
      <td><input type="checkbox" class="model-pick-cb" data-idx="${idx}" ${isBet ? 'checked' : ''} onchange="updateModelSelectAll()"></td>
      <td><span class="badge badge-source">${p.source}</span></td>
      <td><div class="log-pick-main">${p.pick}</div></td>
      <td><span class="log-sport-text">${p.sport}</span></td>
      <td><span class="log-odds-text">${oddsStr}</span></td>
      <td><span class="log-odds-text">${probStr}</span></td>
      <td><span class="log-odds-text">${edgeStr}</span></td>
      <td class="${cls}"><span class="log-pl-text">${p.decision}</span></td>
    </tr>`;
  }).join('');
  const addSelectedBtn = document.getElementById('btn-add-selected');
  if (addSelectedBtn) {
    addSelectedBtn.disabled = false;
  }
  const addAllBtn = document.getElementById('btn-add-picks');
  if (addAllBtn) {
    const betCount = picks.filter(p => p.decision === 'BET').length;
    addAllBtn.disabled = betCount === 0;
    addAllBtn.textContent = 'ADD ALL BET PICKS TO LEDGER';
  }
  updateModelSelectAll();
}

function _normalizeTeam(t) {
  // Normalize team names for comparison: lowercase, strip whitespace
  return t.trim().toLowerCase().replace(/[^a-z0-9\s]/g, '').replace(/\s+/g, ' ');
}

function _extractMatchupTeams(pickText) {
  // Extract the two team names from "(TeamA vs/@ TeamB)" in a pick string
  const parens = Array.from(String(pickText || '').matchAll(/\(([^)]+)\)/g), m => m[1].trim());
  const inside = parens.find(s => /\s+(vs|@)\s+/i.test(s) && !/inc\.?\s*ot/i.test(s))
    || parens.find(s => /\s+(vs|@)\s+/i.test(s));
  if (!inside) return null;
  const parts = inside.split(/\s+(?:vs|@)\s+/i);
  if (parts.length !== 2) return null;
  return [_normalizeTeam(parts[0]), _normalizeTeam(parts[1])].sort();
}

function _extractPickSide(pickText) {
  // Extract the bet side (team name or Over/Under) from before the parentheses
  const head = pickText.split('(')[0].trim().toLowerCase();
  // Remove spread numbers, ML suffix
  return head.replace(/\s*[+-]?\d+(\.\d+)?\s*$/, '').replace(/\s+ml$/, '').trim();
}

function _marketKey(pickText) {
  // Canonical market key used for fuzzy duplicate checks.
  const head = pickText
    .split('(')[0]
    .trim()
    .toLowerCase()
    .replace(/\s+/g, ' ')
    .replace(/[\u2013\u2014]/g, '-')
    .replace(/\s+ml$/, '');
  return head;
}

function _isDuplicatePick(existingPick, newPick, dateStr) {
  // Same source, same date is the first filter
  if (existingPick.source !== newPick.source) return false;
  if (existingPick.date !== dateStr) return false;
  if (String(existingPick.sport || '').toUpperCase() !== String(newPick.sport || '').toUpperCase()) return false;

  // Exact text match
  if (existingPick.pick === newPick.pick) return true;

  // Fuzzy match: same game + same side (team or over/under direction)
  const existTeams = _extractMatchupTeams(existingPick.pick);
  const newTeams = _extractMatchupTeams(newPick.pick);
  if (!existTeams || !newTeams) return false;

  // Same game? (teams match regardless of order)
  if (existTeams[0] !== newTeams[0] || existTeams[1] !== newTeams[1]) return false;

  // Same market for the same game?
  return _marketKey(existingPick.pick) === _marketKey(newPick.pick);
}

function toggleAllModelPicks(checked) {
  document.querySelectorAll('.model-pick-cb').forEach(cb => { cb.checked = checked; });
}

function updateModelSelectAll() {
  const all = document.querySelectorAll('.model-pick-cb');
  const checked = document.querySelectorAll('.model-pick-cb:checked');
  const selectAll = document.getElementById('model-select-all');
  if (selectAll) {
    selectAll.checked = all.length > 0 && checked.length === all.length;
    selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
  }
  const btn = document.getElementById('btn-add-selected');
  if (btn) {
    btn.textContent = `ADD ${checked.length} SELECTED PICK(S) TO LEDGER`;
    btn.disabled = checked.length === 0;
  }
}

function _appendModelPicksToLedger(candidates) {
  const today = new Date();
  const dateStr = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  const existingAdded = getAddedPicks();
  // Respect deleted IDs when checking duplicates, but keep max ID monotonic.
  const activeLedgerPicks = getAllLedgerPicks();
  const allKnownPicks = [...PICKS, ...existingAdded];
  const maxId = allKnownPicks.reduce((m, p) => Math.max(m, Number(p.id) || 0), 0);

  let added = 0;
  let skippedDuplicates = 0;
  const newEntries = [];

  candidates.forEach(p => {
    const source = String(p.source || 'Model');
    const pickText = String(p.pick || '').trim();
    if (!pickText) return;

    const shaped = {
      source,
      pick: pickText,
      sport: String(p.sport || 'Other'),
      units: Number(p.units) || 1,
      odds: normalizeOddsValue(p.odds),
      probability: normalizeProbabilityValue(p.probability),
    };

    const isDup = [...activeLedgerPicks, ...newEntries].some(ep => _isDuplicatePick(ep, shaped, dateStr));
    if (isDup) {
      skippedDuplicates++;
      return;
    }

    newEntries.push({
      id: maxId + 1 + added,
      date: dateStr,
      source: shaped.source,
      pick: shaped.pick,
      sport: shaped.sport,
      units: shaped.units,
      odds: shaped.odds,
      probability: shaped.probability,
      result: 'pending'
    });
    added++;
  });

  if (newEntries.length) {
    saveAddedPicks([...existingAdded, ...newEntries]);
  }

  return { added, skippedDuplicates };
}

function addSelectedPicksToLedger() {
  const checked = document.querySelectorAll('.model-pick-cb:checked');
  if (!checked.length) { alert('No picks selected.'); return; }

  const indices = Array.from(checked).map(cb => parseInt(cb.dataset.idx));
  const selected = indices.map(i => pendingModelPicks[i]).filter(Boolean);

  const { added } = _appendModelPicksToLedger(selected);
  render();
  const btn = document.getElementById('btn-add-selected');
  if (added > 0) {
    btn.textContent = `${added} PICK(S) ADDED — VIEW IN HOME TAB`;
    switchTab('home');
  } else {
    btn.textContent = 'NO NEW PICKS ADDED (DUPLICATES)';
  }
}

function addModelPicksToLedger() {
  const betPicks = pendingModelPicks.filter(p => p.decision === 'BET');
  if (!betPicks.length) { alert('No BET picks to add.'); return; }

  const { added } = _appendModelPicksToLedger(betPicks);
  render();
  const addAllBtn = document.getElementById('btn-add-picks');
  if (added > 0) {
    addAllBtn.textContent = `${added} PICK(S) ADDED — VIEW IN HOME TAB`;
    switchTab('home');
  } else {
    addAllBtn.textContent = 'NO NEW BET PICKS ADDED (DUPLICATES)';
  }
}

function initScores24SyncMeta() {
  const cached = getScores24CachedFeed();
  if (cached && cached.meta) {
    setScores24SyncMeta(cached.meta);
  } else {
    setScores24SyncMeta(null);
  }
}

function initSportyTraderSyncMeta() {
  const cached = getSportyTraderCachedFeed();
  if (cached && cached.meta) {
    setSportyTraderSyncMeta(cached.meta);
  } else {
    setSportyTraderSyncMeta(null);
  }
}

initTheme();
initScores24SyncMeta();
initSportyTraderSyncMeta();
syncWithServer().catch(() => setSyncStatus('offline'));
loadNbaPropsGames();
const savedTab = localStorage.getItem('pickledger_tab') || 'home';
if (savedTab !== 'home') switchTab(savedTab);
render();
if (missingStartTimesCount() > 0) {
  refreshAutoGrades(true);
}
(async () => {
  const restored = await pullLedgerStateIfNeeded();
  if (!restored && hasMeaningfulLocalState()) {
    scheduleLedgerStateSync();
    pushLedgerState(true);
  }
})();
