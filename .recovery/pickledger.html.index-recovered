<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PickLedger</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080b0f; --surface: #0e1318; --card: #131920; --border: #1e2932;
    --accent: #00e5a0; --accent3: #4da6ff; --gold: #ffd700;
    --text: #e8edf2; --muted: #5a7085; --danger: #ff4560;
    --win: #00e5a0; --loss: #ff4560; --push: #ffd700;
    --grid-line: rgba(0,229,160,0.03);
    --shadow-soft: 0 18px 40px rgba(0,0,0,0.18);
    --panel-tint: transparent;
  }
  body[data-theme="light"] {
    --bg: #f0f2f5; --surface: #f7f9fc; --card: #ffffff; --border: #dde2e8;
    --accent: #0b9d74; --accent3: #2563eb; --gold: #ab8400;
    --text: #0f1923; --muted: #607080; --danger: #d93b59;
    --win: #00a870; --loss: #e5304f; --push: #b08800;
    --grid-line: rgba(37,99,235,0.04);
    --shadow-soft: 0 4px 20px rgba(15,25,40,0.08), 0 1px 4px rgba(15,25,40,0.04);
    --panel-tint: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(247,249,252,0.98));
  }

  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; overflow-x: hidden; transition: background-color 0.3s, color 0.3s; }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(circle at 12% 14%, rgba(0,229,160,0.08), transparent 28%),
      radial-gradient(circle at 88% 10%, rgba(77,166,255,0.08), transparent 24%),
      linear-gradient(180deg, rgba(255,255,255,0.015), transparent 28%);
    pointer-events: none;
    z-index: 0;
  }
  body[data-theme="light"]::before {
    background:
      radial-gradient(ellipse at 20% 0%, rgba(37,99,235,0.08) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 0%, rgba(11,157,116,0.07) 0%, transparent 45%),
      linear-gradient(180deg, #f0f2f5, #f7f9fc);
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.018) 48%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }
  body[data-theme="light"]::after { display: none; }
  .container { position: relative; z-index: 1; max-width: 1440px; margin: 0 auto; padding: 28px 22px 34px; }
  body[data-theme="light"] .container { max-width: 1480px; padding: 34px 26px 40px; }

  /* Header */
  header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; padding-bottom: 20px; border-bottom: 1px solid var(--border); transition: border-color 0.3s; }
  body[data-theme="light"] header {
    align-items: flex-start;
    margin-bottom: 20px;
    padding: 8px 0 32px;
    border-bottom: 1px solid var(--border);
  }
  .logo-title { font-family: 'Bebas Neue', sans-serif; font-size: 42px; letter-spacing: 3px; line-height: 1; background: linear-gradient(135deg, var(--accent) 0%, var(--accent3) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .logo-sub { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 2px; margin-top: 4px; }
  .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .header-controls { display: flex; align-items: center; gap: 8px; }
  .header-stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: var(--accent); text-align: right; }
  .header-stat-label { font-size: 11px; color: var(--muted); letter-spacing: 1px; text-align: right; }
  body[data-theme="light"] .logo-title {
    font-family: 'Fraunces', serif;
    font-size: 54px;
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 0.95;
    text-transform: none;
  }
  body[data-theme="light"] .logo-sub {
    margin-top: 10px;
    font-size: 10px;
    letter-spacing: 2.4px;
  }
  body[data-theme="light"] .header-right {
    gap: 14px;
  }
  body[data-theme="light"] .header-stat-val {
    font-family: 'Fraunces', serif;
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -1px;
  }
  body[data-theme="light"] .header-stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Theme toggle */
  .theme-toggle { display: flex; align-items: center; gap: 7px; background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 5px 10px 5px 8px; cursor: pointer; transition: border-color 0.2s, background-color 0.3s; user-select: none; }
  .theme-toggle:hover { border-color: var(--accent); }
  .refresh-btn { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 6px 12px; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1px; cursor: pointer; transition: border-color 0.2s, color 0.2s, opacity 0.2s; }
  .refresh-btn:hover { border-color: var(--accent); color: var(--text); }
  .refresh-btn:disabled { opacity: 0.65; cursor: wait; }
  .refresh-status { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.5px; color: var(--muted); text-align: right; min-height: 14px; }
  .refresh-status.error { color: var(--danger); }
  .refresh-status.ok { color: var(--accent3); }
  .toggle-icon { font-size: 12px; line-height: 1; }
  .toggle-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1px; color: var(--muted); min-width: 32px; }
  .toggle-track { width: 34px; height: 18px; background: var(--border); border-radius: 9px; position: relative; flex-shrink: 0; transition: background-color 0.3s; }
  body[data-theme="light"] .toggle-track { background: var(--accent); }
  .toggle-thumb { width: 12px; height: 12px; background: var(--muted); border-radius: 50%; position: absolute; top: 3px; left: 3px; transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), background-color 0.3s; }
  body[data-theme="light"] .toggle-thumb { transform: translateX(16px); background: #fff; }
  body[data-theme="light"] .theme-toggle,
  body[data-theme="light"] .refresh-btn,
  body[data-theme="light"] .filter-btn,
  body[data-theme="light"] .filter-more-btn,
  body[data-theme="light"] .model-league-select,
  body[data-theme="light"] .result-select {
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px);
  }

  /* Tabs */
  .tabs { display: flex; gap: 4px; margin: 0 0 30px 0; border-bottom: 2px solid var(--border); }
  .tab { background: none; border: none; padding: 14px 22px; font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 1.8px; color: var(--muted); cursor: pointer; position: relative; transition: color 0.2s, transform 0.2s; }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); }
  .tab.active::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background: var(--accent); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  .tab:focus-visible { outline: 2px solid var(--accent3); outline-offset: 2px; }
  body[data-theme="light"] .tabs {
    gap: 6px;
    margin-bottom: 34px;
    padding: 6px;
    border-bottom: none;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: #ffffff;
    box-shadow: 0 2px 12px rgba(15,25,40,0.06);
  }
  body[data-theme="light"] .tab {
    padding: 10px 20px;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--muted);
  }
  body[data-theme="light"] .tab.active {
    color: var(--text);
    background: var(--bg);
    box-shadow: 0 1px 4px rgba(15,25,40,0.08);
  }
  body[data-theme="light"] .tab.active::after {
    display: none;
  }

  /* Filter pills */
  .filter-bar { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; align-items: center; position: relative; }
  .filter-btn { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; color: var(--muted); padding: 8px 16px; font-family: 'DM Mono', monospace; font-size: 14px; letter-spacing: 0.5px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .filter-btn:hover { border-color: var(--accent); color: var(--text); }
  .filter-btn.active { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 700; }
  .filter-more-wrap { position: relative; display: inline-block; }
  .filter-more-btn { width: 36px; height: 36px; border-radius: 50%; background: var(--surface); border: 1px solid var(--border); color: var(--muted); font-size: 20px; font-family: 'DM Sans', sans-serif; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; line-height: 1; }
  .filter-more-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-more-btn.has-selection { border-color: var(--accent); color: var(--accent); background: rgba(0,229,160,0.08); }
  body[data-theme="light"] .filter-more-btn.has-selection { background: rgba(0,168,112,0.08); }
  .filter-dropdown { display: none; position: absolute; top: calc(100% + 6px); right: 0; background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 6px; min-width: 180px; z-index: 100; box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  body[data-theme="light"] .filter-dropdown { box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .filter-dropdown.open { display: flex; flex-direction: column; gap: 2px; }
  .filter-dropdown .filter-btn { text-align: left; border-radius: 4px; width: 100%; }

  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 34px; letter-spacing: 1.8px; color: var(--muted); margin-bottom: 18px; }
  .panel { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 28px; margin-bottom: 34px; transition: background-color 0.3s, border-color 0.3s, box-shadow 0.3s, transform 0.25s; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; margin-bottom: 34px; }
  .stat-box { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; transition: background-color 0.3s, border-color 0.3s, box-shadow 0.3s; }
  .stat-box-val { font-family: 'Bebas Neue', sans-serif; font-size: 40px; line-height: 0.95; }
  .stat-box-label { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-top: 6px; letter-spacing: 0.6px; }
  body[data-theme="light"] .section-title {
    margin-bottom: 20px;
    font-family: 'Fraunces', serif;
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--text);
    line-height: 1;
  }
  body[data-theme="light"] .section-title.clean-title {
    position: relative;
    padding-left: 20px;
  }
  body[data-theme="light"] .section-title.clean-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    width: 5px;
    height: 32px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent3), var(--accent));
  }
  body[data-theme="light"] .panel {
    border-radius: 16px;
    padding: 28px;
    border-color: var(--border);
  }
  body[data-theme="light"] .stats-grid {
    gap: 14px;
  }
  body[data-theme="light"] .stat-box {
    border-radius: 14px;
    padding: 20px 20px 22px;
    border-color: var(--border);
  }
  body[data-theme="light"] .stat-box-val,
  body[data-theme="light"] .trend-summary-val,
  body[data-theme="light"] .sport-units {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    letter-spacing: -1px;
    font-size: 44px;
  }
  body[data-theme="light"] .stat-box-label,
  body[data-theme="light"] .trend-summary-label {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .positive { color: var(--win); } .negative { color: var(--loss); } .neutral { color: var(--push); }

  /* Leaderboard */
  .leaderboard { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; margin-bottom: 34px; }
  .source-card { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 24px; position: relative; overflow: hidden; transition: transform 0.2s, border-color 0.2s, background-color 0.3s, box-shadow 0.2s; cursor: pointer; }
  .source-card:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 18px 34px rgba(0,0,0,0.16); }
  .source-card.rank-1 { border-color: var(--gold); }
  .source-card.rank-1::before { content: '\2605  BEST SOURCE'; position: absolute; top: 10px; right: 10px; font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 1px; color: var(--gold); background: rgba(255,215,0,0.1); padding: 3px 7px; border-radius: 3px; }
  .source-card.rank-2 { border-color: rgba(192,192,192,0.5); }
  .source-card.rank-3 { border-color: rgba(205,127,50,0.5); }
  .card-rank { font-family: 'Bebas Neue', sans-serif; font-size: 52px; color: var(--border); position: absolute; bottom: -8px; right: 12px; line-height: 1; user-select: none; }
  .rank-1 .card-rank { color: rgba(255,215,0,0.15); }
  .card-name { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 0.9px; margin-bottom: 14px; }
  .score-bar-wrap { margin-bottom: 12px; }
  .score-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 4px; font-family: 'DM Mono', monospace; }
  .score-val { color: var(--text); font-weight: 500; }
  .bar-bg { height: 5px; background: var(--border); border-radius: 2.5px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 2.5px; transition: width 0.6s ease; }
  .bar-acc { background: var(--accent3); } .bar-roi { background: var(--accent); } .bar-score { background: linear-gradient(90deg, var(--accent), var(--accent3)); }
  .algo-score { display: flex; align-items: center; gap: 10px; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border); }
  .algo-score-val { font-family: 'Bebas Neue', sans-serif; font-size: 40px; line-height: 1; }
  .algo-score-info { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; line-height: 1.6; }
  .sport-board { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin-bottom: 30px; }
  .sport-card { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 20px; transition: box-shadow 0.25s, border-color 0.25s, transform 0.2s; }
  .sport-card:hover { transform: translateY(-2px); box-shadow: 0 14px 28px rgba(0,0,0,0.14); }
  .sport-name { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.9px; font-size: 26px; }
  .sport-meta { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-top: 6px; line-height: 1.7; }
  .sport-units { font-family: 'Bebas Neue', sans-serif; font-size: 36px; line-height: 0.95; margin-top: 12px; }
  .algo-box { background: rgba(0,229,160,0.04); border: 1px solid rgba(0,229,160,0.2); border-radius: 10px; padding: 16px; margin-bottom: 32px; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); line-height: 1.8; transition: background-color 0.3s, border-color 0.3s; }
  body[data-theme="light"] .algo-box { background: rgba(0,168,112,0.05); border-color: rgba(0,168,112,0.25); }
  .algo-box strong { color: var(--accent); }

  /* === Table (used for Model Results, not Home pick log) === */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 14px; }
  thead tr { border-bottom: 2px solid var(--border); }
  th { text-align: left; padding: 10px 14px 10px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1.5px; color: var(--muted); font-weight: 500; text-transform: uppercase; }
  td { padding: 12px 14px; border-bottom: 1px solid var(--border); transition: background-color 0.15s; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }

  /* === Pick Log Feed (Home tab) === */
  .pick-feed { display: flex; flex-direction: column; gap: 0; }
  .pick-feed-empty { text-align: center; padding: 50px 20px; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 13px; }

  /* Game header */
  .game-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 20px 4px 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }
  .game-header:first-child { padding-top: 6px; }
  .game-header-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 1.2px;
    color: var(--text);
    line-height: 1;
  }
  .game-header-meta {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.3px;
  }

  /* Individual pick bubble */
  .pick-bubble {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    margin: 0;
    border-bottom: 1px solid rgba(128,128,128,0.08);
    transition: background-color 0.2s, transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s;
    flex-wrap: wrap;
    cursor: default;
  }
  .pick-bubble:last-child { border-bottom: none; }
  .pick-bubble:hover, .pick-bubble.hover-active, .pick-bubble:focus-within {
    background: var(--surface);
    transform: scale(1.06) translateY(-2px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.18), 0 4px 12px rgba(0,0,0,0.12);
    z-index: 20;
    position: relative;
    border-radius: 12px;
  }
  .pick-bubble-source {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.5px;
    font-weight: 400;
    padding: 6px 14px;
    border-radius: 20px;
    background: rgba(77,166,255,0.14);
    color: var(--accent3);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 90px;
    text-align: center;
  }
  .pick-bubble-pick {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.2px;
    flex: 1;
    min-width: 180px;
  }
  .pick-bubble-odds {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }
  .pick-bubble-result {
    flex-shrink: 0;
  }
  .pick-bubble-pl {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.5px;
    min-width: 42px;
    text-align: right;
    flex-shrink: 0;
  }
  /* Game block wrapper */
  .game-block {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    margin-bottom: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .game-block:hover {
    border-color: rgba(77,166,255,0.25);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .game-block-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 16px 20px 12px;
    background: linear-gradient(90deg, rgba(77,166,255,0.10) 0%, transparent 60%);
    border-bottom: 1px solid var(--border);
  }
  .game-block-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1.4px;
    color: var(--text);
    line-height: 1;
  }
  .game-block-meta {
    font-family: 'DM Mono', monospace;
    font-size: 15px;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.3px;
  }
  .game-block-picks {
    padding: 4px 4px;
  }

  /* Light mode pick feed overrides */
  body[data-theme="light"] .game-block {
    background: #ffffff;
    border-color: var(--border);
    box-shadow: 0 1px 6px rgba(15,25,40,0.05);
  }
  body[data-theme="light"] .game-block:hover {
    border-color: rgba(37,99,235,0.3);
    box-shadow: 0 10px 30px rgba(15,25,40,0.1);
  }
  body[data-theme="light"] .game-block-header {
    background: linear-gradient(90deg, rgba(37,99,235,0.07) 0%, transparent 60%);
    border-bottom-color: var(--border);
  }
  body[data-theme="light"] .pick-bubble:hover, 
  body[data-theme="light"] .pick-bubble.hover-active,
  body[data-theme="light"] .pick-bubble:focus-within {
    background: #ffffff;
    box-shadow: 0 20px 50px rgba(15,25,40,0.15), 0 8px 16px rgba(15,25,40,0.08);
  }
  body[data-theme="light"] .pick-bubble-source {
    background: rgba(37,99,235,0.10);
    color: var(--accent3);
  }

  .log-date-text,
  .log-sport-text,
  .log-odds-text,
  .log-pl-text {
    font-family: 'DM Mono', monospace;
  }

  .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-family: 'DM Mono', monospace; letter-spacing: 0.4px; font-weight: 600; }
